class console_manager
{
string[] args;
console_manager()
{
parse_args();
}
bool has_args()
{
return COMMAND_LINE != "";
}
void output(string text)
{
cout<<text;
}
void error(string text)
{
cout<<"error. "+text;
}
string get_input()
{
return cin.read_line().trim_whitespace();
}
string[] parse_args()
{
args = COMMAND_LINE.split(" ");
return args;
}
}