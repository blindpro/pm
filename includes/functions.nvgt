void registor_commands()
{
commands.insert_last(command("new",new));
commands.insert_last(command("sync",sync));
commands.insert_last(command("status",status));
}
void output(string text)
{
cli.output(text);
cli.output("\n");
}
bool is_blank(string str)
{
return str == "";
}
bool in_project()
{
return directory_exists(".pm");
}